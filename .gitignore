# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
!.env.example
*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------
# Private DB / SQL / backup artifacts
# ------------------------------------------------------------
# The public application repository must not version operational SQL,
# dumps, backups, private migrations, private seeds or production DB scripts.
# Keep executable DB assets in a private repository or local ignored folder.

# Generic SQL and DB backup artifacts
*.sql
*.sql.gz
*.sql.zip
*.dump
*.backup
*.bak
*.pgdump
*.psql
*.sqlite
*.sqlite3
*.db

# Common backup/export folders
/backups/
/backup/
/dumps/
/dump/
/exports/
/logs/

# Project DB folders that must stay private in the public repo
/database/scripts/
/database/migrations/
/database/pending_migrations/
/database/private/
/database/local/
/database/remote/
/database/backups/
/database/dumps/
/database/seeds/
/database/tmp/

# Supabase runtime/private DB artifacts
/supabase/.branches/
/supabase/.temp/
/supabase/.shadow/
/supabase/.data/
/supabase/db/
/supabase/seed.sql
/supabase/seeds/
/supabase/snippets/
/supabase/migrations/

# Secret-like generated files
# Nota: no usar patrones globales como *password* o *token* porque bloquean
# archivos fuente válidos, por ejemplo auth/forgot-password y servicios de reset.
# Los secretos reales quedan cubiertos por .env*, *.sql, dumps y extensiones comunes.
*secret*.env
*secret*.json
*secret*.txt
*token*.env
*token*.json
*token*.txt
*password*.env
*password*.json
*password*.txt
*service-role*
*service_role*
*anon-key*
*anon_key*

# Playwright / E2E artifacts
/playwright-report/
/test-results/
/e2e/.auth/
